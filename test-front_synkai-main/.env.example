# Copia a .env.local para desarrollo o ajusta .env.production antes del build.
#
# Desarrollo: deja VUE_APP_API_URL vacío o en /api y usa el proxy de vue.config.js
# Producción: URL absoluta del API (con /api al final)
#
VUE_APP_API_URL=/api
# Origen del backend para el proxy del dev server (npm run serve)
VUE_APP_BACKEND_ORIGIN=http://127.0.0.1:8000
